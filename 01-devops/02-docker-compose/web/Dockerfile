# Dockerfile for Node.js Express Web Application
#
# Complete this Dockerfile to create a container for the Express app.
#
# The application is a simple web server that connects to PostgreSQL.

# TODO: Use node:18-alpine as the base image
FROM

# TODO: Set working directory to /app
WORKDIR

# TODO: Copy package.json and package-lock.json
# Hint: COPY package*.json ./
COPY

# TODO: Install dependencies (npm install)
# For production, use: npm ci --only=production
RUN

# TODO: Copy the rest of the application code
# Hint: COPY . .
COPY

# TODO: Expose port 3000
EXPOSE

# TODO: Set the command to start the server
# Hint: CMD ["node", "app.js"]
CMD
